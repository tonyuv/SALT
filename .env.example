# Copy this file to .env and fill in your API key:
#   cp .env.example .env
#
# Get your key at: https://console.anthropic.com/settings/keys
#
# Without this key, the health-check agent runs in rule-based mode (no AI).
# With it, Claude Haiku analyzes each health check and provides intelligent summaries.
ANTHROPIC_API_KEY=sk-ant-your-key-here
